#!/usr/bin/env python3
import glob
import subprocess
import sys
import tomllib
from pathlib import Path

LAB_DIR = Path(__file__).resolve().parent
TOPO = LAB_DIR / "topology.clab.yml"
BRIEF_FILE = LAB_DIR / ".current-brief"
APPLIED_FILE = LAB_DIR / ".applied-components"

LAB_NAME = "ot-defence-workbench"
BOUNDARY = f"clab-{LAB_NAME}-boundary"
PROBE = f"clab-{LAB_NAME}-probe"
CLIENT = f"clab-{LAB_NAME}-client"

RUNNER_CONTAINER = {"probe": PROBE, "client": CLIENT}


def current_brief_num():
    try:
        return int(BRIEF_FILE.read_text().strip())
    except (FileNotFoundError, ValueError):
        return 1


def brief_path(n=None):
    if n is None:
        n = current_brief_num()
    matches = sorted(glob.glob(str(LAB_DIR / "briefs" / f"{n:02d}-*.toml")))
    return Path(matches[0]) if matches else None


def load_brief(n=None):
    p = brief_path(n)
    if not p:
        return None
    with open(p, "rb") as f:
        return tomllib.load(f)


def docker_exec(container, cmd, capture=False):
    full = ["docker", "exec", container] + cmd
    if capture:
        r = subprocess.run(full, capture_output=True)
        return r.returncode
    return subprocess.run(full).returncode


def _bridge_exists(name):
    return subprocess.run(
        ["ip", "link", "show", name], capture_output=True
    ).returncode == 0


def _ensure_bridges():
    for name in ("north", "south"):
        if not _bridge_exists(name):
            subprocess.run(["ip", "link", "add", name, "type", "bridge"], check=True)
            subprocess.run(["ip", "link", "set", name, "up"], check=True)


def _delete_bridges():
    for name in ("north", "south"):
        subprocess.run(["ip", "link", "delete", name], capture_output=True)


def cmd_up(_args):
    _ensure_bridges()
    for service in ("asset", "client", "probe", "boundary"):
        subprocess.run(
            ["docker", "build", "-t", f"ot-workbench/{service}:latest",
             str(LAB_DIR / service)],
            check=True,
        )
    subprocess.run(["clab", "deploy", "-t", str(TOPO)], check=True)


def cmd_down(_args):
    subprocess.run(["clab", "destroy", "-t", str(TOPO)])
    _delete_bridges()


def cmd_brief(_args):
    brief = load_brief()
    if not brief:
        print("No brief found.")
        return
    b = brief["brief"]
    print(f"\nbrief {b['number']} · {b['slug']}\n")
    print(b["title"])
    print()
    print(b["requirement"].strip())
    print()


def cmd_build(args):
    if not args:
        sys.exit("Usage: lab build <component>")
    component = args[0]
    comp_dir = LAB_DIR / "components" / component
    apply_script = comp_dir / "apply.sh"
    if not apply_script.exists():
        sys.exit(f"No apply.sh for component: {component}")
    subprocess.run(
        ["docker", "cp", str(apply_script), f"{BOUNDARY}:/tmp/component-apply.sh"],
        check=True,
    )
    rc = docker_exec(BOUNDARY, ["/bin/sh", "/tmp/component-apply.sh"])
    if rc != 0:
        sys.exit(f"Failed to build: {component}")
    applied = set(APPLIED_FILE.read_text().splitlines()) if APPLIED_FILE.exists() else set()
    applied.add(component)
    APPLIED_FILE.write_text("\n".join(sorted(applied)))
    print(f"built: {component}")


def cmd_remove(args):
    if not args:
        sys.exit("Usage: lab remove <component>")
    component = args[0]
    comp_dir = LAB_DIR / "components" / component
    remove_script = comp_dir / "remove.sh"
    if not remove_script.exists():
        sys.exit(f"No remove.sh for component: {component}")
    subprocess.run(
        ["docker", "cp", str(remove_script), f"{BOUNDARY}:/tmp/component-remove.sh"],
        check=True,
    )
    rc = docker_exec(BOUNDARY, ["/bin/sh", "/tmp/component-remove.sh"])
    if rc != 0:
        sys.exit(f"Failed to remove: {component}")
    if APPLIED_FILE.exists():
        applied = set(APPLIED_FILE.read_text().splitlines())
        applied.discard(component)
        APPLIED_FILE.write_text("\n".join(sorted(applied)))
    print(f"removed: {component}")


def _run_custom_probes():
    custom_dir = LAB_DIR / "probe" / "custom"
    scripts = sorted(
        p for p in custom_dir.iterdir()
        if p.suffix in (".py", ".sh") and not p.name.startswith("_")
    ) if custom_dir.exists() else []

    results = []
    for script in scripts:
        dest = f"/tmp/custom-{script.name}"
        subprocess.run(
            ["docker", "cp", str(script), f"{PROBE}:{dest}"],
            capture_output=True,
        )
        cmd = ["python3", dest] if script.suffix == ".py" else ["/bin/sh", dest]
        rc = docker_exec(PROBE, cmd, capture=True)
        results.append({"name": script.name, "actual": "pass" if rc == 0 else "block"})
    return results


_PROBE_TEMPLATE = """\
#!/usr/bin/env python3
# {name}: describe what this probe checks.
# Exit 0 = reached/succeeded (pass).  Exit 1 = blocked/failed (block).
import sys
from pymodbus.client import ModbusTcpClient

TARGET = "10.0.2.10"
PORT = 502

client = ModbusTcpClient(TARGET, port=PORT, timeout=2)
if not client.connect():
    sys.exit(1)

# Replace with the operation you want to test.
result = client.read_holding_registers(0, 1)
client.close()

sys.exit(0 if not result.isError() else 1)
"""


def cmd_probe(args):
    if args and args[0] == "add":
        if len(args) < 2:
            sys.exit("Usage: lab probe add <name>")
        name = args[1]
        custom_dir = LAB_DIR / "probe" / "custom"
        custom_dir.mkdir(exist_ok=True)
        dest = custom_dir / f"{name}.py"
        if dest.exists():
            sys.exit(f"Already exists: {dest}")
        dest.write_text(_PROBE_TEMPLATE.format(name=name))
        dest.chmod(0o755)
        print(f"Created {dest.relative_to(LAB_DIR)} — edit it, then run ./lab check.")
        return

    brief = load_brief()
    if not brief:
        print("No brief loaded.")
        return
    b = brief["brief"]
    checks = brief.get("checks", [])

    RUNNER_DIR = {"probe": LAB_DIR / "probe", "client": LAB_DIR / "client"}

    print(f"\nbrief {b['number']} · {b['slug']} — probe battery\n")
    for check in checks:
        runner = check["runner"]
        name = check["name"]
        script_name = Path(check["script"]).name
        src = RUNNER_DIR[runner] / "checks" / script_name
        print(f"  [{runner}]  {name}  ({check['script']})")
        print()
        if src.exists():
            for line in src.read_text().splitlines():
                print(f"    {line}")
        else:
            print("    (source not found)")
        print()

    custom_dir = LAB_DIR / "probe" / "custom"
    if custom_dir.exists():
        custom = sorted(
            p for p in custom_dir.iterdir()
            if p.suffix in (".py", ".sh") and not p.name.startswith("_")
        )
        if custom:
            print(f"  CUSTOM PROBES\n")
            for script in custom:
                print(f"  {script.name}")
                print()
                for line in script.read_text().splitlines():
                    print(f"    {line}")
                print()


def cmd_check(_args):
    brief = load_brief()
    if not brief:
        print("No brief loaded.")
        return
    b = brief["brief"]
    checks = brief.get("checks", [])

    results = []
    for check in checks:
        runner = check["runner"]
        name = check["name"]
        script = check["script"]
        expect = check["expect"]

        container = RUNNER_CONTAINER.get(runner)
        if not container:
            print(f"unknown runner: {runner}", file=sys.stderr)
            continue

        rc = docker_exec(container, ["python3", script], capture=True)
        actual = "pass" if rc == 0 else "block"
        results.append(
            {"runner": runner, "name": name, "expect": expect,
             "actual": actual, "held": actual == expect}
        )

    custom = _run_custom_probes()

    print(f"\nbrief {b['number']} · {b['slug']}\n")

    w = 26
    adversary = [r for r in results if r["runner"] == "probe"]
    legitimate = [r for r in results if r["runner"] == "client"]

    if adversary:
        print(f"{'ADVERSARY CHECKS':<{w}}  {'EXPECT':<8}  {'RESULT':<8}")
        for r in adversary:
            mark = "+" if r["held"] else "!"
            print(f"  {r['name']:<{w-2}}  {r['expect']:<8}  {r['actual']:<8}  {mark}")

    print()

    if legitimate:
        print(f"{'LEGITIMATE CHECKS':<{w}}  {'EXPECT':<8}  {'RESULT':<8}")
        for r in legitimate:
            mark = "+" if r["held"] else "!"
            print(f"  {r['name']:<{w-2}}  {r['expect']:<8}  {r['actual']:<8}  {mark}")

    if custom:
        print()
        print(f"{'CUSTOM PROBES':<{w}}  {'RESULT':<8}")
        for r in custom:
            print(f"  {r['name']:<{w-2}}  {r['actual']:<8}")

    print()
    all_held = all(r["held"] for r in results)
    print("HEADLINE: HELD" if all_held else "HEADLINE: OPEN")
    print()


def cmd_next(_args):
    n = current_brief_num()
    next_n = n + 1
    if not brief_path(next_n):
        print(f"No brief {next_n}. End of ladder.")
        return
    BRIEF_FILE.write_text(str(next_n))
    if APPLIED_FILE.exists():
        APPLIED_FILE.unlink()
    _reset_boundary()
    print(f"Advanced to brief {next_n}.")
    cmd_brief([])


def cmd_reset(_args):
    BRIEF_FILE.write_text("1")
    if APPLIED_FILE.exists():
        APPLIED_FILE.unlink()
    _reset_boundary()
    print("Reset to brief 1, boundary flat.")


def _reset_boundary():
    docker_exec(
        BOUNDARY,
        ["/bin/sh", "-c", "iptables -F FORWARD && iptables -P FORWARD ACCEPT"],
    )


COMMANDS = {
    "up": cmd_up,
    "down": cmd_down,
    "brief": cmd_brief,
    "probe": cmd_probe,
    "build": cmd_build,
    "remove": cmd_remove,
    "check": cmd_check,
    "next": cmd_next,
    "reset": cmd_reset,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print("usage: lab <command> [args]")
        print("commands:", "  ".join(COMMANDS))
        sys.exit(1)
    COMMANDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()